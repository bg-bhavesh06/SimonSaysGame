<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="/CSS/style2.css">
</head>

  <body>
    <form action="/login" method="post" class="needs-validation" >
      <div class="card">
        <a href="/signup" class="signup-link" style="text-decoration: none;">signup?</a>
         <% if (error) { %>
      <div style="font-size: 22px; color:red ; text-align:center; margin-bottom:17px ;">
        <%= error %>
      </div>
    <% } %>
        
        <h2>Login To Play</h2>
      </div>

      <div>
        <label class="f form-label">Gmail :</label>
        <input type="email" class="form-control" name="listing[gmail]" value="<%= gmail || '' %>" required/>
        <br /><br />
        
        <label class="f form-label">
          Password :
          <a id="a" href="/forget">Forgot?</a>
        </label>

        <input type="password" class="form-control" name="listing[password]" required />
        <br /><br />

        <button type="submit" class="submited">SUBMIT</button>
      </div>
    </form>
     <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  </body>
</html>
